<?xml version="1.0" encoding="utf-8"?>
<!-- ScrollTax notification icon — white S-scroll bars on transparent bg.
     Android 5+ requires notification small icons to be flat/white. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top bar — right-aligned (stadium shape) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M10.75,5.5 L19.75,5.5 A1.25,1.25 0 0,1 19.75,8 L10.75,8 A1.25,1.25 0 0,1 10.75,5.5 Z"/>

    <!-- Middle bar — full width, slightly taller -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M4.5,10.5 L19.5,10.5 A1.5,1.5 0 0,1 19.5,13.5 L4.5,13.5 A1.5,1.5 0 0,1 4.5,10.5 Z"/>

    <!-- Bottom bar — left-aligned, 75% opacity -->
    <group android:alpha="0.75">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M4.25,16 L13.25,16 A1.25,1.25 0 0,1 13.25,18.5 L4.25,18.5 A1.25,1.25 0 0,1 4.25,16 Z"/>
    </group>

</vector>
